# Host port for the all-in-one Sub-Store web service.
SUB_STORE_PORT=3000

# Time zone used by cron jobs and logs.
TZ=Asia/Hong_Kong

# Frontend source fetched during Docker image build.
# Use a tag such as 2.16.83 when you want reproducible builds.
SUB_STORE_FRONTEND_REPO=https://github.com/sub-store-org/Sub-Store-Front-End.git
SUB_STORE_FRONTEND_REF=master
